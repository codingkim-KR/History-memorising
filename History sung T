<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>한국사 시험 범위 정리 노트 — 개항기 · 근대</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&family=Gowun+Batang:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --paper:#f5f3ec;
  --paper2:#fbfaf5;
  --ink:#23282b;
  --ink-soft:#3a4145;
  --muted:#6f7873;
  --green:#2b6157;
  --green-d:#1d433c;
  --green-l:#5d8d83;
  --red:#a5392c;
  --red-d:#7e2b21;
  --brass:#b8924e;
  --brass-d:#8a6a32;
  --parch:#efe9d8;
  --parch-line:#ddd2b4;
  --line:#dcd6c6;
  --line-soft:#e6e1d3;
  --shadow:0 1px 2px rgba(40,40,30,.05),0 6px 18px rgba(40,40,30,.06);
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;background:var(--paper);color:var(--ink);
  font-family:'Noto Sans KR',sans-serif;font-weight:400;
  line-height:1.85;font-size:16px;overflow-x:hidden;
  -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;
}
.wrap{max-width:980px;margin:0 auto;padding:0 22px 120px}

/* ---------- COVER ---------- */
.cover{
  position:relative;margin:0 -22px 0;padding:64px 22px 54px;
  background:
    radial-gradient(120% 140% at 80% -10%, rgba(43,97,87,.14), transparent 55%),
    linear-gradient(180deg,#26514a 0%, #1d433c 100%);
  color:#f3efe3;overflow:hidden;
}
.cover:before{
  content:"";position:absolute;inset:0;
  background-image:repeating-linear-gradient(90deg, rgba(255,255,255,.035) 0 1px, transparent 1px 46px);
  pointer-events:none;
}
.cover .eyebrow{
  font-family:'Noto Sans KR';font-weight:500;letter-spacing:.32em;font-size:12.5px;
  color:#cdb98a;text-transform:uppercase;margin:0 0 16px;
}
.cover h1{
  font-family:'Nanum Myeongjo',serif;font-weight:800;
  font-size:clamp(31px,6vw,52px);line-height:1.18;margin:0 0 14px;letter-spacing:-.01em;
}
.cover h1 .accent{color:#e3b04f;display:block;font-size:.62em;font-weight:700;margin-top:8px;letter-spacing:.02em;color:#d9c79a}
.cover .sub{max-width:640px;font-size:15.5px;color:#d6cfba;font-weight:300;line-height:1.7;margin:0}
.cover .scope-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:24px}
.cover .scope-tags span{
  font-size:12.5px;font-weight:500;color:#e8e0cb;
  border:1px solid rgba(220,205,160,.4);border-radius:40px;padding:5px 13px;
  background:rgba(255,255,255,.04);
}

/* ---------- MASTER TIMELINE ---------- */
.mtl-wrap{margin:0 -22px;padding:30px 22px 34px;background:#eceadf;border-bottom:1px solid var(--line)}
.mtl-h{font-family:'Nanum Myeongjo',serif;font-weight:700;font-size:14px;letter-spacing:.06em;color:var(--green-d);margin:0 0 6px}
.mtl-note{font-size:12.5px;color:var(--muted);margin:0 0 18px}
.mtl{display:flex;gap:0;overflow-x:auto;padding-bottom:8px;scrollbar-width:thin}
.mtl .ev{flex:0 0 auto;min-width:118px;text-align:center;position:relative;padding-top:26px}
.mtl .ev:before{content:"";position:absolute;top:5px;left:0;right:0;height:2px;background:var(--brass)}
.mtl .ev:first-child:before{left:50%}
.mtl .ev:last-child:before{right:50%}
.mtl .ev .dot{position:absolute;top:0;left:50%;transform:translateX(-50%);width:11px;height:11px;border-radius:50%;background:var(--green);border:2px solid #eceadf;box-shadow:0 0 0 1px var(--green)}
.mtl .ev .yr{font-family:'Nanum Myeongjo',serif;font-weight:800;font-size:18px;color:var(--red)}
.mtl .ev .lb{font-size:12.5px;font-weight:500;color:var(--ink-soft);margin-top:2px;padding:0 6px;line-height:1.45}

/* ---------- TOC ---------- */
.toc{margin:34px 0 6px;background:var(--paper2);border:1px solid var(--line);border-radius:14px;padding:22px 24px;box-shadow:var(--shadow)}
.toc h2{font-family:'Nanum Myeongjo',serif;font-size:17px;margin:0 0 14px;color:var(--green-d);font-weight:800;display:flex;align-items:center;gap:9px}
.toc h2 .ic{width:20px;height:20px;border-radius:5px;background:var(--green);display:inline-block}
.toc ol{margin:0;padding:0;list-style:none;columns:2;column-gap:34px}
.toc li{break-inside:avoid;margin:0 0 4px}
.toc a{color:var(--ink-soft);text-decoration:none;font-size:14.3px;font-weight:400;display:flex;gap:9px;padding:3px 6px;border-radius:6px;transition:background .15s,color .15s}
.toc a:hover{background:#eef1ec;color:var(--green-d)}
.toc a .n{color:var(--brass-d);font-weight:700;font-family:'Nanum Myeongjo',serif;min-width:20px}
@media(max-width:620px){.toc ol{columns:1}}

/* ---------- PART ---------- */
.part{margin:60px 0 0;scroll-margin-top:14px}
.part-head{border-bottom:3px solid var(--green);padding-bottom:12px;margin-bottom:6px;position:relative}
.part-eye{font-family:'Noto Sans KR';font-weight:700;letter-spacing:.22em;font-size:12px;color:var(--brass-d);text-transform:uppercase;display:block;margin-bottom:7px}
.part-head h2{font-family:'Nanum Myeongjo',serif;font-weight:800;font-size:clamp(24px,4.6vw,33px);margin:0;line-height:1.22;color:var(--ink);letter-spacing:-.01em}
.part-head h2 .pn{color:var(--green);margin-right:12px}

/* sub-section */
h3.sub{font-family:'Nanum Myeongjo',serif;font-weight:700;font-size:21px;margin:38px 0 4px;color:var(--green-d);display:flex;align-items:baseline;gap:11px;letter-spacing:-.005em}
h3.sub .bar{flex:0 0 5px;height:21px;background:var(--brass);border-radius:2px;transform:translateY(3px)}
h4.subsub{font-family:'Noto Sans KR';font-weight:700;font-size:16.5px;color:var(--red-d);margin:24px 0 2px;letter-spacing:-.005em}

p{margin:12px 0}
.lead{font-size:16px;color:var(--ink-soft)}

/* key terms */
.term{color:var(--red);font-weight:700}
.term2{color:var(--green-d);font-weight:700}
b,strong{font-weight:700;color:var(--ink)}
.hanja{color:var(--muted);font-weight:400;font-size:.9em}
.yr{display:inline-block;font-family:'Nanum Myeongjo',serif;font-weight:700;font-size:.86em;color:#fff;background:var(--green);border-radius:5px;padding:1px 7px;margin:0 1px;letter-spacing:.01em;vertical-align:.05em}
.yr.r{background:var(--red)}

/* bullet lists */
ul.clean{list-style:none;margin:12px 0;padding:0}
ul.clean>li{position:relative;padding:4px 0 4px 22px;line-height:1.78}
ul.clean>li:before{content:"";position:absolute;left:3px;top:14px;width:6px;height:6px;border-radius:50%;background:var(--green-l)}
ul.clean ul{list-style:none;margin:4px 0 4px;padding:0}
ul.clean ul>li{position:relative;padding:2px 0 2px 20px;font-size:14.7px;color:var(--ink-soft)}
ul.clean ul>li:before{content:"–";position:absolute;left:3px;top:2px;color:var(--brass-d);font-weight:700}

/* ---------- SOURCE BOX (사료) ---------- */
.src{margin:22px 0;background:var(--parch);border:1px solid var(--parch-line);border-left:5px solid var(--brass);border-radius:0 10px 10px 0;overflow:hidden;box-shadow:var(--shadow)}
.src-top{display:flex;align-items:center;gap:10px;padding:11px 18px 9px;background:linear-gradient(180deg,#e8dfc6,#e3d9bd);border-bottom:1px dashed var(--brass)}
.src-badge{font-family:'Noto Sans KR';font-weight:700;font-size:11.5px;letter-spacing:.18em;color:#fff;background:#4a3f26;border-radius:4px;padding:3px 10px;flex:0 0 auto}
.src-title{font-family:'Nanum Myeongjo',serif;font-weight:700;font-size:15.5px;color:#4a3a1c;letter-spacing:-.005em}
.src-body{padding:14px 20px 6px}
.src-body p{margin:0 0 9px}
.src-q{font-family:'Gowun Batang','Nanum Myeongjo',serif;font-size:15px;color:#3a3322;line-height:1.82}
.src-q .em{color:var(--red-d);font-weight:700;font-family:'Noto Sans KR'}
.src-cite{display:block;text-align:right;font-size:12.5px;color:var(--brass-d);font-weight:500;margin:2px 0 12px;font-style:italic}
.src .multi{border-top:1px dotted var(--parch-line);padding-top:11px;margin-top:4px}
.src .multi:first-child{border-top:none;padding-top:0}
.src-sub{font-weight:700;color:var(--green-d);font-size:14px;margin:0 0 4px;font-family:'Noto Sans KR'}
.src ol.art{margin:4px 0 10px;padding-left:0;list-style:none;counter-reset:art}
.src ol.art>li{position:relative;padding:3px 0 3px 30px;font-size:14.5px;color:#3a3322;line-height:1.7}
.src ol.art>li .anum{position:absolute;left:0;top:3px;font-family:'Nanum Myeongjo',serif;font-weight:700;color:var(--brass-d);font-size:13px}

/* ---------- NOTE / 용어 aside ---------- */
.note{margin:16px 0;background:#edf1ea;border:1px solid #d6e0d4;border-radius:10px;padding:13px 17px}
.note .nh{font-weight:700;font-size:13.5px;color:var(--green-d);margin:0 0 3px;display:flex;align-items:center;gap:7px}
.note .nh:before{content:"用";font-family:'Nanum Myeongjo',serif;font-size:12px;background:var(--green);color:#fff;width:18px;height:18px;display:grid;place-items:center;border-radius:4px;flex:0 0 auto}
.note p{margin:0;font-size:14px;color:var(--ink-soft);line-height:1.7}
.note + .note{margin-top:9px}

/* ---------- VERDICT (의의·한계) ---------- */
.verdict{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:20px 0}
.verdict .v{border-radius:11px;padding:14px 17px;font-size:14.4px;line-height:1.72}
.verdict .v.pro{background:#e8f0ec;border:1px solid #c7ddd2}
.verdict .v.con{background:#f3e8e4;border:1px solid #e2c8bf}
.verdict .v h5{margin:0 0 6px;font-size:13.5px;font-weight:700;letter-spacing:.02em}
.verdict .v.pro h5{color:var(--green-d)}
.verdict .v.con h5{color:var(--red-d)}
@media(max-width:620px){.verdict{grid-template-columns:1fr}}

/* ---------- TABLE ---------- */
.tbl-wrap{margin:20px 0;overflow-x:auto;border-radius:11px;border:1px solid var(--line);box-shadow:var(--shadow)}
table.tbl{border-collapse:collapse;width:100%;min-width:440px;background:var(--paper2);font-size:14.3px}
table.tbl th,table.tbl td{padding:10px 14px;text-align:left;vertical-align:top;border-bottom:1px solid var(--line-soft);line-height:1.6}
table.tbl thead th{background:var(--green-d);color:#f1ede0;font-weight:700;font-size:13.5px;letter-spacing:.02em;border-bottom:none}
table.tbl tbody tr:last-child td{border-bottom:none}
table.tbl tbody tr:nth-child(even){background:#f0eee5}
table.tbl td.k{font-weight:700;color:var(--green-d);white-space:nowrap;background:#eef1ea}
table.tbl .em{color:var(--red);font-weight:700}

/* ---------- MINI TIMELINE (연표) ---------- */
.ftl{margin:18px 0;border-left:2px solid var(--brass);padding-left:0}
.ftl .row{position:relative;padding:5px 0 5px 26px;font-size:14.5px}
.ftl .row:before{content:"";position:absolute;left:-5px;top:13px;width:8px;height:8px;border-radius:50%;background:var(--green);border:2px solid var(--paper)}
.ftl .row .d{font-family:'Nanum Myeongjo',serif;font-weight:700;color:var(--red);margin-right:9px}

/* flow arrow chain */
.flow{display:flex;flex-wrap:wrap;align-items:center;gap:7px 4px;margin:16px 0;padding:14px 16px;background:var(--paper2);border:1px dashed var(--line);border-radius:11px}
.flow .step{background:#eef1ea;border:1px solid #d4ddd0;border-radius:8px;padding:6px 11px;font-size:13.6px;font-weight:500;color:var(--green-d)}
.flow .step.hot{background:#f4e7e3;border-color:#e3c7be;color:var(--red-d);font-weight:700}
.flow .ar{color:var(--brass-d);font-weight:700;font-size:14px}

/* divider */
.dvd{height:1px;background:var(--line);margin:30px 0;border:0}
.special-tag{display:inline-block;font-size:11.5px;font-weight:700;letter-spacing:.08em;color:#fff;background:var(--brass-d);border-radius:20px;padding:3px 11px;margin-bottom:4px}

/* back to top */
#top{position:fixed;right:18px;bottom:18px;width:46px;height:46px;border-radius:50%;background:var(--green-d);color:#f1ede0;border:none;cursor:pointer;box-shadow:0 4px 14px rgba(29,67,60,.4);font-size:19px;opacity:0;pointer-events:none;transition:opacity .25s;z-index:50}
#top.show{opacity:1;pointer-events:auto}
#top:hover{background:var(--green)}

/* print */
@media print{
  body{background:#fff;font-size:11pt;line-height:1.5}
  .cover{background:#1d433c !important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  #top{display:none}
  .part{page-break-inside:auto}
  .src,.tbl-wrap,.verdict{page-break-inside:avoid}
  .toc a{color:#333}
  *{-webkit-print-color-adjust:exact;print-color-adjust:exact}
}
@media(max-width:600px){
  body{font-size:15.3px}
  .wrap{padding:0 16px 90px}
  .cover{margin:0 -16px;padding:48px 16px 40px}
  .mtl-wrap{margin:0 -16px;padding:24px 16px 28px}
}
</style>
</head>
